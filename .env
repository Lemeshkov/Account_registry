# .env
ENVIRONMENT=development
BUILD_TARGET=development

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=account_registry
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Database URL для SQLAlchemy (для локального запуска)
DATABASE_URL=postgresql+psycopg2://admin:admin123@localhost:5432/account_registry

# Redis URL для локального запуска
REDIS_URL=redis://localhost:6379/0

# PgAdmin (опционально)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Redis Commander (опционально)
REDIS_COMMANDER_PORT=8081

# Дополнительные настройки
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True